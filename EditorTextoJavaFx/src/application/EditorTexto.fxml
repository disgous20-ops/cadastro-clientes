<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Controller">
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Arquivo">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#novoArquivo" text="Novo" />
                  <MenuItem mnemonicParsing="false" onAction="#abrirArquivo" text="Abrir" />
                  <MenuItem mnemonicParsing="false" onAction="#salvarArquivo" text="Salva" />
                  <MenuItem mnemonicParsing="false" onAction="#salvarArquivoComo" text="Salvar Como" />
                  <MenuItem mnemonicParsing="false" onAction="#sair" text="Sair" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Editar">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#copiar" text="Copiar" />
                  <MenuItem mnemonicParsing="false" onAction="#colar" text="Colar" />
                  <MenuItem mnemonicParsing="false" onAction="#selecionarTudo" text="Selecionar Tudo" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Aparência">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#modoClaro" text="Claro" />
                  <MenuItem mnemonicParsing="false" onAction="#modoEscuro" text="Escuro" />
            </items>
          </Menu>
            <Menu mnemonicParsing="false" text="Ajuda">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#exibirInformacoes" text="Sobre" />
               </items>
            </Menu>
        </menus>
      </MenuBar>
   </top>
   <center>
      <TextArea fx:id="textArea" minHeight="200.0" minWidth="200.0" prefHeight="200.0" prefWidth="200.0" style="-fx-control-inner-background: #282a36; -fx-background-color: #282a36; -fx-text-fill: #ffffff;" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
